_: ''
  // Mouse — Niri has built-in Mod+drag (move) and Mod+Right-drag (resize).
  // Scroll wheel: switch workspaces
  Mod+WheelScrollDown    cooldown-ms=150 { focus-workspace-down; }
  Mod+WheelScrollUp      cooldown-ms=150 { focus-workspace-up; }

  // Touchpad (hold Mod+Ctrl to drag, Mod+Alt to resize)
  // NOTE: built-in Mod+drag already handles this — these are kept for reference.
  // Niri does NOT expose move-window / resize-column as keybind actions.
''
