_: ''
  # Panels
  bindsym $mod+comma          exec $ipc settings-toggle
  bindsym $mod+d              exec $ipc panel-toggle launcher
  bindsym $mod+Escape         exec $ipc panel-toggle session
  bindsym $mod+Ctrl+v         exec $ipc panel-toggle clipboard
  bindsym $mod+Ctrl+space     exec $ipc panel-toggle wallpaper
  bindsym $mod+period         exec $ipc panel-toggle control-center
''
