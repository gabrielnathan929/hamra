_: ''
  # Toggles
  bindsym XF86WLAN                exec $ipc wifi-toggle
  bindsym XF86RFKill              exec $ipc wifi-toggle
  bindsym $mod+Ctrl+w          exec $ipc wifi-toggle
  bindsym $mod+Ctrl+n          exec $ipc nightlight-toggle
  bindsym $mod+Ctrl+b          exec $ipc bluetooth-toggle
  bindsym $mod+Ctrl+c          exec $ipc caffeine-toggle
  bindsym $mod+Ctrl+p          exec $ipc power-cycle
''
